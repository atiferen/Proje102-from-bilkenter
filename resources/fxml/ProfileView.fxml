<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frombilkenter.fx.controller.ProfileController"
      spacing="18" styleClass="content-root">
    <children>
        <Label fx:id="nameLabel" styleClass="page-title"/>
        <GridPane hgap="16" vgap="16">
            <children>
                <Label text="Department" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="muted-label"/>
                <Label fx:id="departmentValue" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Active Listings" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="muted-label"/>
                <Label fx:id="activeListingsValue" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Completed Sales" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="muted-label"/>
                <Label fx:id="completedSalesValue" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Status" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="muted-label"/>
                <Label fx:id="statusValue" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
        <HBox spacing="12">
            <children>
                <Button text="Edit Profile" onAction="#openEditProfile" styleClass="primary-button"/>
                <Button text="Change Password" onAction="#openChangePassword" styleClass="secondary-button"/>
            </children>
        </HBox>
        <Label text="My Requests" styleClass="section-title"/>
        <TableView fx:id="requestsTable" prefHeight="220">
            <columns>
                <TableColumn fx:id="requestTitleColumn" text="Title" prefWidth="290"/>
                <TableColumn fx:id="requestCategoryColumn" text="Category" prefWidth="200"/>
                <TableColumn fx:id="requestPriceColumn" text="Price" prefWidth="130"/>
                <TableColumn fx:id="requestStatusColumn" text="Status" prefWidth="180"/>
                <TableColumn fx:id="requestDateColumn" text="Submitted" prefWidth="180"/>
            </columns>
        </TableView>
        <Label text="My Listings" styleClass="section-title"/>
        <FlowPane fx:id="myListingsPane" hgap="18" vgap="18" prefWrapLength="980"/>
        <Label text="Favorites" styleClass="section-title"/>
        <FlowPane fx:id="favoritesPane" hgap="18" vgap="18" prefWrapLength="980"/>
    </children>
    <padding>
        <Insets top="34" right="70" bottom="50" left="70"/>
    </padding>
</VBox>
