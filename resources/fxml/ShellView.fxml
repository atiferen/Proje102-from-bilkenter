<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="frombilkenter.fx.controller.ShellController"
            styleClass="shell-root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="24" styleClass="top-nav">
            <children>
                <ImageView fx:id="logoImage" fitWidth="56" fitHeight="56" preserveRatio="true"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="homeButton" text="Home" onAction="#showHome" styleClass="nav-button"/>
                <Button fx:id="sellButton" text="Sell" onAction="#showSell" styleClass="nav-button"/>
                <Button fx:id="leaderboardButton" text="Leaderboard" onAction="#showLeaderboard" styleClass="nav-button"/>
                <Button fx:id="profileButton" text="Profile" onAction="#showProfile" styleClass="nav-button"/>
                <Button fx:id="adminButton" text="Admin Panel" onAction="#showAdmin" styleClass="nav-button"/>
                <Button text="Sign Out" onAction="#signOut" styleClass="nav-button"/>
            </children>
            <padding>
                <Insets top="16" right="28" bottom="16" left="28"/>
            </padding>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentHost" styleClass="page-host"/>
    </center>
</BorderPane>
